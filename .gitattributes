# ── Generated audio ──────────────────────────────────────────────────
media/audio/*.mp3              filter=lfs diff=lfs merge=lfs -text

# ── Built Anki package ───────────────────────────────────────────────
*.apkg                         filter=lfs diff=lfs merge=lfs -text

# ── Diagrams / images (future) ───────────────────────────────────────
media/timelines/*.svg          filter=lfs diff=lfs merge=lfs -text
media/images/*.jpg             filter=lfs diff=lfs merge=lfs -text
media/images/*.png             filter=lfs diff=lfs merge=lfs -text

# ── Pitch-accent data ────────────────────────────────────────────────
data/pitch-accent/*.sqlite     filter=lfs diff=lfs merge=lfs -text
data/pitch-accent/*.txt        filter=lfs diff=lfs merge=lfs -text
data/pitch-accent/*.csv        filter=lfs diff=lfs merge=lfs -text
data/pitch-accent/nhk/**       filter=lfs diff=lfs merge=lfs -text

# ── Dictionaries (compressed XML/TSV blobs) ──────────────────────────
data/dictionaries/*.gz         filter=lfs diff=lfs merge=lfs -text
data/dictionaries/*.bz2        filter=lfs diff=lfs merge=lfs -text
data/dictionaries/*.zip        filter=lfs diff=lfs merge=lfs -text

# ── Frequency lists (CSVs, sometimes large) ──────────────────────────
data/frequency-lists/**/*.csv  filter=lfs diff=lfs merge=lfs -text
data/frequency-lists/**/*.tsv  filter=lfs diff=lfs merge=lfs -text
data/frequency-lists/**/*.json filter=lfs diff=lfs merge=lfs -text

# ── Corpora ──────────────────────────────────────────────────────────
data/corpora/**                filter=lfs diff=lfs merge=lfs -text

# ── Furigana / pitch indices (regenerable, but small enough to track) ──
media/furigana_index.json      filter=lfs diff=lfs merge=lfs -text
media/pitchaccent_index.json   filter=lfs diff=lfs merge=lfs -text
media/words_index.json         filter=lfs diff=lfs merge=lfs -text
